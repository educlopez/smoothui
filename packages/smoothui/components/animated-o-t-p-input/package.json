{
  "name": "@repo/animated-o-t-p-input",
  "description": "A AnimatedOTPInput component for SmoothUI.",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@repo/shadcn-ui": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "motion": "^12.23.25",
    "lucide-react": "^0.545.0",
    "input-otp": "^1.2.4"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "typescript": "^5.9.3"
  },
  "smoothui": {
    "category": "basic-ui",
    "tags": [
      "otp",
      "input",
      "verification",
      "code",
      "pin",
      "form",
      "animated"
    ],
    "complexity": "moderate",
    "animationType": "tween",
    "useCases": [
      "One-time password input for two-factor authentication",
      "Verification code entry with animated digit slots",
      "PIN code input with staggered entrance animations"
    ],
    "compositionHints": [
      "Combine with basic-modal for verification dialogs",
      "Use basic-toast to show verification success/error"
    ],
    "hasReducedMotion": true
  }
}
